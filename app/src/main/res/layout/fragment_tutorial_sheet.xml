<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="40dp">

    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:letterSpacing="0.12"
                android:text="@string/tutorial_label"
                android:textAllCaps="true"
                android:textColor="@color/amber"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@drawable/card_surface_high"
            android:gravity="center"
            android:text="×"
            android:textColor="@color/text_secondary"
            android:textSize="20sp"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Section 1: Pre-Mission -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp">

                <TextView
                    android:id="@+id/icon_1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_status_icon_box_healthy"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="@color/status_healthy"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:text="@string/tutorial_pre_mission_title"
                    android:textColor="@color/status_healthy"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:layout_marginTop="22dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/tutorial_pre_mission_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Section 2: Active Mission -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp">

                <TextView
                    android:id="@+id/icon_2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_status_icon_box_healthy"
                    android:gravity="center"
                    android:text="→"
                    android:textColor="@color/map_position"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:text="@string/tutorial_active_mission_title"
                    android:textColor="@color/map_position"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:layout_marginTop="22dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/tutorial_active_mission_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Section 3: Voice Commands -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp">

                <TextView
                    android:id="@+id/icon_3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_status_icon_box_degraded"
                    android:gravity="center"
                    android:text="♪"
                    android:textColor="@color/amber"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:text="@string/tutorial_voice_title"
                    android:textColor="@color/amber"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="42dp"
                    android:layout_marginTop="22dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/tutorial_voice_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
