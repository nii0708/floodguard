<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_screen">


    <!-- Alert Banner — conditional, slides in from top -->
    <LinearLayout
        android:id="@+id/alert_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/status_critical"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_alert_icon_box"
                android:gravity="center"
                android:text="&#x26A0;"
                android:textColor="@android:color/white"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:letterSpacing="0.02"
                android:text="@string/alert_revisit_title"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/alert_subtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:alpha="0.85"
            android:text="@string/alert_revisit_info_sample"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="3dp"
            android:text="@string/alert_revisit_action"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/alert_auto_dismiss_progress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/bg_alert_progress" />
    </LinearLayout>

    <!-- Mode Banner — always visible, sticky below alert -->
    <LinearLayout
        android:id="@+id/mode_banner"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alert_banner">

        <TextView
            android:id="@+id/mode_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_banner_text"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <View
            android:id="@+id/rec_dot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_dot_critical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:letterSpacing="0.1"
            android:text="REC"
            android:textColor="@color/status_critical"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Separator line under mode banner -->
    <View
        android:id="@+id/mode_banner_separator"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/border_default"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_banner" />

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_banner_separator">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="13dp"
            android:paddingBottom="22dp">

            <!-- 1. Status Pill -->
            <LinearLayout
                android:id="@+id/status_pill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill_healthy"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_healthy" />

                <TextView
                    android:id="@+id/status_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/system_status_healthy"
                    android:textColor="@color/status_healthy"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tracking_mode_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_healthy"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="AR VIO"
                    android:textColor="@color/status_healthy"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 2. TANYA AI / ASK AI Button -->
            <LinearLayout
                android:id="@+id/btn_ask_ai"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_ask_ai_idle"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mic_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/btn_ask_ai_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:letterSpacing="0.05"
                    android:text="@string/btn_ask_ai"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 3. Waktu + Camera view grid (5 : 7) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <!-- Waktu + Landmark card (weight 5) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:background="@drawable/card_surface"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.12"
                        android:text="@string/metric_elapsed_label"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/metric_elapsed_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="-0.04"
                        android:text="00:00"
                        android:textColor="@color/text_primary"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <!-- Divider ~60% width -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="14dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/border_subtle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="@string/metric_landmark_label"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/metric_landmark_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="-0.03"
                        android:text="0"
                        android:textColor="@color/map_position"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 10dp gap -->
                <Space
                    android:layout_width="10dp"
                    android:layout_height="match_parent" />

                <!-- Camera view card (weight 7) -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="7"
                    android:background="@drawable/card_camera"
                    android:clipToOutline="true"
                    android:minHeight="134dp">

                    <!-- ARCore live camera feed -->
                    <android.opengl.GLSurfaceView
                        android:id="@+id/ar_surface_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- AR decorations overlay -->
                    <com.floodguard.rescue.ui.CameraOverlayView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Top-left: blinking cam dot + CAM·1 label -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/cam_dot"
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/bg_dot_critical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:alpha="0.5"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.1"
                            android:text="CAM·1"
                            android:textColor="@android:color/white"
                            android:textSize="8sp" />
                    </LinearLayout>

                    <!-- Top-right: LIVE label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:alpha="0.3"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05"
                        android:text="LIVE"
                        android:textColor="@android:color/white"
                        android:textSize="7sp" />

                    <!-- Bottom gradient strip: AR OVERLAY + fps -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_camera_bottom_strip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:alpha="0.85"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.06"
                            android:text="AR OVERLAY"
                            android:textColor="@color/status_healthy"
                            android:textSize="7sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="30fps"
                            android:textColor="@color/text_tertiary"
                            android:textSize="7sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- 4. Audio & Tracking Card -->
            <LinearLayout
                android:id="@+id/audio_tracking_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/card_surface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"
                android:paddingVertical="13dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="@string/metric_audio_label"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tracking_mode_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="AR VIO"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/audio_status_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/audio_active_bullet"
                        android:textColor="@color/status_healthy"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/listening_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:letterSpacing="0.03"
                        android:text="@string/listening_hint"
                        android:textColor="@color/amber"
                        android:textSize="11sp"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5. Battery Card -->
            <LinearLayout
                android:id="@+id/battery_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/card_surface"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingVertical="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.1"
                        android:text="@string/metric_battery_label"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/battery_pct_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="-0.03"
                        android:text="100%"
                        android:textColor="@color/battery_high"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/battery_bar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="13dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="100"
                    android:progressDrawable="@drawable/bg_battery_progress" />
            </LinearLayout>

            <!-- 6. Stop / Finish Button -->
            <Button
                android:id="@+id/btn_stop"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_stop_outlined"
                android:text="@string/btn_stop_mission"
                android:textColor="@color/status_critical"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
